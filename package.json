{
  "name": "lukas-angular-zeugs",
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "electron": "electron .",
    "electron:build": "ng build --configuration production --base-href ./",
    "electron:run": "npm run electron:build && electron .",
    "dist": "npm run electron:build && electron-builder"
  },
  "build": {
    "appId": "de.lukas.lukasangularzeugs",
    "productName": "LukasAngularZeugs",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "files": [
      "index.js",
      "package.json",
      "!release{,/**/*}",
      "!docs{,/**/*}"
    ],
    "extraResources": [
      {
        "from": "dist/LukasAngularZeugs/browser",
        "to": "dist"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.5",
    "@angular/cli": "^21.1.5",
    "@angular/compiler-cli": "^21.1.0",
    "angular-cli-ghpages": "^3.0.3",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
